# an configuration
# Copy to .env and adjust.

# HTTP port
PORT=8080

# PostgreSQL connection string
DB_CONNECTION=postgres://an:an@localhost:5432/an?sslmode=disable

# Root credential (header X-AN-API-KEY). When set, every endpoint except
# /health and /.well-known/ requires a key: this bootstrap key (any tenant
# + key management) or a tenant-scoped key minted via POST /api/apikeys.
# When empty, api key auth is DISABLED — dev only.
BOOTSTRAP_API_KEY=

# Tenant used when a request omits tenantId
DEFAULT_TENANT_ID=default

# Rate limit (requests per second, per instance)
REQUESTS_PER_SECOND=20

# CORS
CORS_ENABLED=false
ALLOWED_WEB_ORIGINS=
DOMAIN=

# JWT claims
ISSUER=an
AUDIENCE=an

# Token lifetimes
ACCESS_TOKEN_EXPIRE_IN_SECONDS=3600
REFRESH_TOKEN_EXPIRE_IN_SECONDS=86400

# Password hashing (bcrypt cost)
PASSWORD_COST=12

# Lockout
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_IN_SEC=900

# Magic logon codes
MAGIC_CODE_EXPIRE_IN_SECONDS=600

# Password reset tokens
RESET_TOKEN_EXPIRE_IN_SECONDS=3600

# Google social sign-in; unset disables the provider
GOOGLE_CLIENT_ID=
